{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ask_user": {
      "command": [
        "/usr/local/bin/autocoder",
        "mcp-ask-user-server"
      ],
      "enabled": true,
      "environment": {
        "ORCH_DAEMON_CONTROL_SOCKET": "/home/autocoder/.local/state/autocoder/runtime/control.sock",
        "ORCH_MCP_CHANGE": "contradiction_check",
        "ORCH_MCP_ROLE": "contradiction_check",
        "ORCH_MCP_WORKSPACE": "/home/autocoder/.cache/autocoder/workspaces/github_com_IndustriousKraken_octopus-autocoder",
        "ORCH_MCP_WORKSPACE_BASENAME": "github_com_IndustriousKraken_octopus-autocoder"
      },
      "type": "local"
    }
  },
  "permission": {
    "bash": "deny",
    "edit": "deny",
    "webfetch": "deny"
  },
  "provider": {
    "ollama": {
      "models": {
        "gemma4:latest": {}
      },
      "name": "ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://10.42.11.10:11434/v1"
      }
    }
  }
}